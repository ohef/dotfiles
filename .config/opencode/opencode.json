{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type" : "local",
      "command": ["npx" ,"-y", "chrome-devtools-mcp@latest", "--auto-connect", "--accept-insecure-certs" ],
      "enabled": false
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://ai.ohefn.org:5002/v1"
      },
      "models": {
        "gemma4-q8": {
          "limit": {
            "context": 140000,
            "output": 20000,
          },
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gemma4": {
          "limit": {
            "context": 240000,
            "output": 40000,
          },
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        }
      }
    }
  }
}
